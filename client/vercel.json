{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
